# pipeline.env
# Written by: Makhtar N.
# ─────────────────────────────────────────────────────────────────────────────
# Edit this file before running anything.
# All pipeline scripts source this file for their configuration.
# ─────────────────────────────────────────────────────────────────────────────

# ── paths ─────────────────────────────────────────────────────────────────────

BAG_DIR="/home/faro/octo_fr3/bags_all_51"    # all 51 demo bags (symlinks into 2026_Data)

HDF5_DIR="/home/faro/octo_fr3/HDF5_Data/hdf5_episodes_v2" # extracted episodes go here

TFDS_DIR="/home/faro/octo_fr3/TFDS_Data/tfds_output_v2"   # TFDS dataset goes here

CHECKPOINT_DIR="/home/faro/octo_fr3/checkpoints_v3" # saved model weights go here

OCTO_DIR="/home/faro/octo_fr3/octo"          # octo repo (moved into octo_fr3, not the submodule)

STANDARDIZE_FN_DIR="/home/faro/octo_fr3/src" # where fr3_standardize_fn.py lives

# ── dataset ───────────────────────────────────────────────────────────────────

# Language instruction to label all demonstrations with.
# If you have multiple tasks, run the extract step separately per task.
# Must match the string used at deployment in JointStates_octo_franka_bridge.py
LANGUAGE_INSTRUCTION="Pick up the green pepper and place it in bin"

# ── finetuning ────────────────────────────────────────────────────────────────

# Pretrained Octo checkpoint to start from.
#   hf://rail-berkeley/octo-base-1.5   (93M params, recommended)
#   hf://rail-berkeley/octo-small-1.5  (27M params, lighter)
PRETRAINED_PATH="hf://rail-berkeley/octo-base-1.5"

# Finetuning mode: full | head_mlp_only | head_only
#   full          → recommended for FR3 (new action space + new proprio tokenizer)
#   head_mlp_only → if you have <50 demos and limited compute
FINETUNE_MODE="full"

# Task modality: language_conditioned | image_conditioned | multimodal
TASK_MODALITY="language_conditioned"

# ── wandb ─────────────────────────────────────────────────────────────────────

WANDB_ENTITY="your_wandb_entity"
WANDB_GROUP="fr3_finetune_run1"

# Set to 0 to disable wandb logging
WANDB_ENABLED=0
